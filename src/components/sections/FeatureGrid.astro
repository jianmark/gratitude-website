---
import { getLocale, t, localizedUrl, type Locale } from '@/i18n/utils';

const locale = getLocale(Astro.url) as Locale;

const featureBase = locale === 'it' ? 'funzionalita' : locale === 'de' ? 'funktionen' : locale === 'fr' ? 'fonctionnalites' : locale === 'es' ? 'funcionalidades' : 'features';

const features = [
  { num: 1, icon: 'tablet', slug: 'tablet-checkout', color: 'teal' },
  { num: 2, icon: 'qr', slug: 'qr-code', color: 'teal' },
  { num: 3, icon: 'chart', slug: 'dashboard', color: 'teal' },
  { num: 4, icon: 'calc', slug: locale === 'it' ? 'distribuzione' : locale === 'de' ? 'verteilung' : 'distribution', color: 'teal' },
  { num: 5, icon: 'file', slug: locale === 'it' ? 'report-fiscali' : locale === 'de' ? 'steuerberichte' : locale === 'fr' ? 'rapports-fiscaux' : locale === 'es' ? 'informes-fiscales' : 'fiscal-reports', color: 'teal' },
  { num: 6, icon: 'link', slug: locale === 'it' ? 'integrazione-passepartout' : locale === 'de' ? 'passepartout-integration' : locale === 'fr' ? 'integration-passepartout' : locale === 'es' ? 'integracion-passepartout' : 'passepartout-integration', color: 'teal' },
  { num: 7, icon: 'star', slug: locale === 'it' ? 'feedback-ospiti' : locale === 'de' ? 'gaestefeedback' : locale === 'fr' ? 'feedback-clients' : locale === 'es' ? 'feedback-huespedes' : 'guest-feedback', color: 'teal' },
  { num: 8, icon: 'globe', slug: locale === 'it' ? 'sicurezza' : locale === 'de' ? 'sicherheit' : locale === 'fr' ? 'securite' : locale === 'es' ? 'seguridad' : 'security', color: 'teal' },
];

// SVG icons per feature
const iconSvgs: Record<string, string> = {
  tablet: 'M10.5 19.5h3m-6.75 2.25h10.5a2.25 2.25 0 002.25-2.25v-15a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v15a2.25 2.25 0 002.25 2.25z',
  qr: 'M3.75 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 013.75 9.375v-4.5zM3.75 14.625c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5a1.125 1.125 0 01-1.125-1.125v-4.5zM13.5 4.875c0-.621.504-1.125 1.125-1.125h4.5c.621 0 1.125.504 1.125 1.125v4.5c0 .621-.504 1.125-1.125 1.125h-4.5A1.125 1.125 0 0113.5 9.375v-4.5z',
  chart: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z',
  calc: 'M15.75 15.75V18m-7.5-6.75h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V13.5zm0 2.25h.008v.008H8.25v-.008zm0 2.25h.008v.008H8.25V18zm2.498-6.75h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V13.5zm0 2.25h.007v.008h-.007v-.008zm0 2.25h.007v.008h-.007V18zm2.504-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zm0 2.25h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V18zm2.498-6.75h.008v.008h-.008v-.008zm0 2.25h.008v.008h-.008V13.5zM8.25 6h7.5v2.25h-7.5V6zM12 2.25c-1.892 0-3.758.11-5.593.322C5.307 2.7 4.5 3.65 4.5 4.757V19.5a2.25 2.25 0 002.25 2.25h10.5a2.25 2.25 0 002.25-2.25V4.757c0-1.108-.806-2.057-1.907-2.185A48.507 48.507 0 0012 2.25z',
  file: 'M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z',
  link: 'M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-4.243a4.5 4.5 0 00-6.364 0l-4.5 4.5a4.5 4.5 0 001.242 7.244',
  star: 'M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z',
  globe: 'M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418',
};
---

<section class="section-padding bg-white dark:bg-navy-900" id="features">
  <div class="section-container">
    <p class="text-sm font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider text-center mb-4">
      {t(locale, 'features.section_title')}
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-12">
      {locale === 'it' ? 'Tutto ciò che serve per le mance digitali' : locale === 'de' ? 'Alles für digitales Trinkgeld' : locale === 'fr' ? 'Tout pour le pourboire numérique' : locale === 'es' ? 'Todo para las propinas digitales' : 'Everything you need for digital tipping'}
    </h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map(({ num, icon, slug, color }) => (
        <a
          href={localizedUrl(locale, `/${featureBase}/${slug}/`)}
          class="group p-6 rounded-2xl bg-stone-50 dark:bg-navy-800 border border-stone-200 dark:border-navy-700 hover:border-teal-300 dark:hover:border-teal-700 hover:shadow-md transition-all"
        >
          <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 bg-teal-100 dark:bg-teal-900/30">
            <svg class="w-5 h-5 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d={iconSvgs[icon]} />
            </svg>
          </div>
          <h3 class="text-base font-bold mb-2 group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">
            {t(locale, `features.f${num}.title`)}
          </h3>
          <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed line-clamp-3">
            {t(locale, `features.f${num}.desc`)}
          </p>
          <span class="inline-flex items-center gap-1 mt-3 text-sm font-medium text-teal-600 dark:text-teal-400 group-hover:gap-2 transition-all">
            {t(locale, 'cta.more')}
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
            </svg>
          </span>
        </a>
      ))}
    </div>
  </div>
</section>
