---

<section class="section-padding" id="how-it-works">
  <div class="section-container">
    <p class="text-sm font-semibold text-teal-600 dark:text-teal-400 uppercase tracking-wider text-center mb-4">
      {t(locale, 'how.section_title')}
    </p>
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16">
      {locale === 'it' ? 'Da zero a operativi in un giorno' : locale === 'de' ? 'Von null auf betriebsbereit an einem Tag' : locale === 'fr' ? 'De zéro à opérationnel en un jour' : locale === 'es' ? 'De cero a operativo en un día' : 'From zero to live in one day'}
    </h2>

    <div class="relative">
      <!-- Connection line (desktop) -->
      <div class="hidden lg:block absolute top-16 left-[12.5%] right-[12.5%] h-0.5 bg-gradient-to-r from-teal-300 via-teal-300 to-teal-300 dark:from-teal-700 dark:via-teal-700 dark:to-teal-700" aria-hidden="true"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-6">
        {steps.map((step, i) => (
          <div class="relative text-center">
            <!-- Step number circle -->
            <div class="relative z-10 mx-auto w-12 h-12 rounded-full bg-gradient-to-br from-teal-500 to-teal-600 dark:from-teal-600 dark:to-teal-700 flex items-center justify-center text-white font-bold text-lg shadow-lg mb-6">
              {String(step).padStart(2, '0')}
            </div>

            <!-- Icon -->
            <div class="w-14 h-14 mx-auto rounded-2xl bg-stone-100 dark:bg-navy-800 flex items-center justify-center mb-4">
              <svg class="w-7 h-7 text-teal-600 dark:text-teal-400" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d={stepIcons[i]} />
              </svg>
            </div>

            <h3 class="text-lg font-bold mb-3">{t(locale, `how.step${step}.title`)}</h3>
            <p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed">
              {t(locale, `how.step${step}.desc`)}
            </p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
