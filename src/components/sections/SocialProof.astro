---
import { getLocale, t, type Locale } from '@/i18n/utils';

const locale = getLocale(Astro.url) as Locale;

const stats = [
  { key: 'stats.s1' },
  { key: 'stats.s2' },
  { key: 'stats.s3' },
  { key: 'stats.s4' },
];

const badges = ['gdpr', 'art15', 'aes', 'audit', 'pentest'];
---

<section class="section-padding bg-teal-600 dark:bg-teal-900 text-white" id="social-proof">
  <div class="section-container">
    <p class="text-sm font-semibold text-teal-100 uppercase tracking-wider text-center mb-4">
      {t(locale, 'stats.section_title')}
    </p>

    <!-- Stats counter -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-8 mb-16">
      {stats.map(({ key }) => (
        <div class="text-center">
          <p class="text-4xl md:text-5xl font-bold text-white mb-2">
            {t(locale, `${key}.number`)}
          </p>
          <p class="text-sm text-teal-100 mb-1">
            {t(locale, `${key}.label`)}
          </p>
          <p class="text-xs text-teal-200">
            {t(locale, `${key}.source`)}
          </p>
        </div>
      ))}
    </div>

    <!-- Industry quote -->
    <div class="max-w-3xl mx-auto text-center mb-12">
      <blockquote class="text-lg md:text-xl italic text-white mb-4">
        "{t(locale, 'social.industry_quote')}"
      </blockquote>
      <cite class="text-sm text-teal-200 not-italic">
        — {t(locale, 'social.industry_source')}
      </cite>
    </div>

    <!-- Trust badges -->
    <div class="flex flex-wrap gap-3 justify-center">
      {badges.map((badge) => (
        <span class="inline-flex items-center gap-1.5 px-4 py-2 text-xs font-medium bg-white/15 text-white rounded-full border border-white/25">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" />
          </svg>
          {t(locale, `social.badge.${badge}`)}
        </span>
      ))}
    </div>
  </div>
</section>
