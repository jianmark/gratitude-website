---
import { getLocale, t, getAlternateUrls, type Locale } from '@/i18n/utils';
import { ViewTransitions } from 'astro:transitions';
import '@/styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, ogImage, noindex = false } = Astro.props;
const locale = getLocale(Astro.url) as Locale;
const alternates = getAlternateUrls(Astro.url.pathname);
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = ogImage ?? `/og-image-${locale}.png`;
---

<!doctype html>
<html lang={locale} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="canonical" href={canonicalUrl.href} />

    {alternates.map(({ locale: altLocale, url }) => (
      <link
        rel="alternate"
        hreflang={altLocale === 'it' ? 'it-IT' : altLocale === 'en' ? 'en-GB' : altLocale === 'de' ? 'de-DE' : altLocale === 'fr' ? 'fr-FR' : 'es-ES'}
        href={new URL(url, Astro.site).href}
      />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL('/it/', Astro.site).href} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl.href} />
    <meta property="og:image" content={new URL(ogImageUrl, Astro.site).href} />
    <meta property="og:locale" content={locale === 'it' ? 'it_IT' : locale === 'en' ? 'en_GB' : locale === 'de' ? 'de_DE' : locale === 'fr' ? 'fr_FR' : 'es_ES'} />
    <meta property="og:site_name" content="Gratitude" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImageUrl, Astro.site).href} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Preload fonts -->
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="https://fonts.gstatic.com/s/inter/v18/UcCO3FwrK3iLTeHuS_nVMrMxCp50SjIw2boKoduKmMEVuLyfAZ9hiJ-Ek-_EeA.woff2" />
    <link rel="preload" as="font" type="font/woff2" crossorigin href="https://fonts.gstatic.com/s/playfairdisplay/v37/nuFvD-vYSZviVYUb_rj3ij__anPXJzDwcbmjWBN2PKdFvUDQZNLo_U2r.woff2" />

    <!-- View Transitions -->
    <ViewTransitions />

    <!-- CookieScript — Cookie consent banner (GDPR/ePrivacy) -->
    <!-- NOTA: Sostituire COOKIESCRIPT_ID_PLACEHOLDER con l'ID del progetto CookieScript -->
    <script is:inline type="text/javascript" charset="UTF-8" src="https://cdn.cookie-script.com/s/COOKIESCRIPT_ID_PLACEHOLDER.js"></script>

    <!-- Dark mode script (no FOUC) -->
    <script is:inline>
      (function() {
        const stored = localStorage.getItem('theme');
        if (stored === 'dark' || (!stored && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
        const fontSize = localStorage.getItem('a11y-font');
        if (fontSize) document.documentElement.classList.add(fontSize);
        if (localStorage.getItem('a11y-contrast') === '1') document.documentElement.classList.add('high-contrast');
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col antialiased">
    <!-- Skip link for accessibility -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-teal-600 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:text-sm focus:font-semibold"
    >
      {t(locale, 'a11y.skip')}
    </a>

    <slot />

    <!-- Analytics: Plausible (self-hosted, cookieless — no consent needed) -->
    <script is:inline defer data-domain="gratitude.esseginformatica.it" src="/js/plausible.js"></script>

    <!-- Analytics: Microsoft Clarity (performance category — blocked until consent) -->
    <script is:inline type="text/plain" data-cookiescript="accepted" data-cookiecategory="performance">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window,document,"clarity","script","CLARITY_ID_PLACEHOLDER");
    </script>

    <!-- Tracking events (performance category — blocked until consent) -->
    <script type="text/plain" data-cookiescript="accepted" data-cookiecategory="performance" data-src="/js/tracking.js"></script>
  </body>
</html>
