---
import PageLayout from '@/layouts/PageLayout.astro';
import DemoForm from '@/components/forms/DemoForm';
import { t } from '@/i18n/utils';
const locale = 'de';
const benefits = [
  { title: 'Auf Ihr Haus zugeschnitten', body: 'Keine generische Praesentation. Wir konfigurieren die Demo mit Ihren Abteilungen, Ihrer Zimmeranzahl und Ihren spezifischen Beduerfnissen. Sie sehen genau, wie Gratitude in Ihrem Hotel funktionieren wuerde.' },
  { title: 'Unverbindlich, ohne Druck', body: '30 Minuten mit einem Hospitality-Tech-Experten. Wir beantworten jede technische, operative und steuerliche Frage. Wenn Gratitude nicht zu Ihnen passt, sagen wir es als Erste.' },
  { title: 'Geschaetzte Rendite inklusive', body: 'Am Ende der Demo erhalten Sie eine individuelle Renditeeinschaetzung basierend auf Ihrer durchschnittlichen Auslastung, monatlichen Checkouts und Branchendaten.' },
];
const trustSignals = ['DSGVO-konform -- Ihre Daten sind geschuetzt','110+ Sicherheitstests bestanden','Native Passepartout Welcome Integration','Dedizierter Support'];
---

<PageLayout title={t(locale, 'meta.demo.title')} description={t(locale, 'meta.demo.description')}>
  <section class="section-padding bg-gradient-to-b from-navy-50 to-stone-50 dark:from-navy-950 dark:to-navy-900"><div class="section-container text-center"><h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">Sehen Sie Gratitude in Aktion</h1><p class="text-lg md:text-xl text-stone-600 dark:text-stone-400 max-w-3xl mx-auto">Eine auf Ihr Haus zugeschnittene Demo. 30 Minuten, die Ihr Trinkgeld-Management verwandeln koennen.</p></div></section>
  <section class="section-padding"><div class="section-container"><div class="grid grid-cols-1 lg:grid-cols-5 gap-12 max-w-6xl mx-auto">
    <div class="lg:col-span-2 space-y-8">
      {benefits.map((b, i) => (<div><div class="flex items-center gap-3 mb-2"><span class="flex items-center justify-center w-8 h-8 rounded-full bg-teal-100 text-teal-700 text-sm font-bold dark:bg-teal-900/30 dark:text-teal-400">{i + 1}</span><h3 class="text-lg font-semibold text-navy-800 dark:text-stone-200">{b.title}</h3></div><p class="text-sm text-stone-600 dark:text-stone-400 leading-relaxed ml-11">{b.body}</p></div>))}
      <div class="rounded-xl bg-stone-100 p-6 dark:bg-navy-800/50"><h4 class="text-sm font-semibold text-navy-800 dark:text-stone-200 mb-4">Trust Signals</h4><ul class="space-y-3">{trustSignals.map((s) => (<li class="flex items-center gap-2 text-sm text-stone-600 dark:text-stone-400"><svg class="h-5 w-5 text-teal-600 dark:text-teal-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" /></svg><span>{s}</span></li>))}</ul></div>
    </div>
    <div class="lg:col-span-3"><div class="rounded-2xl border border-stone-200 bg-white p-8 shadow-sm dark:border-navy-700 dark:bg-navy-800/50"><DemoForm locale={locale} client:load /></div><p class="mt-4 text-xs text-stone-500 dark:text-stone-400 text-center">Antwort innerhalb von 24 Geschaeftsstunden. Ihre Daten werden nicht an Dritte weitergegeben.</p></div>
  </div></div></section>
</PageLayout>
