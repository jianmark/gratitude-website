---
import PageLayout from '@/layouts/PageLayout.astro';
import { t } from '@/i18n/utils';

const locale = 'de';

const features = [
  { title: t(locale, 'features.f1.title'), desc: t(locale, 'features.f1.desc'), href: `/${locale}/funktionen/tablet-checkout/`, icon: '📱' },
  { title: t(locale, 'features.f2.title'), desc: t(locale, 'features.f2.desc'), href: `/${locale}/funktionen/qr-code/`, icon: '📲' },
  { title: t(locale, 'features.f3.title'), desc: t(locale, 'features.f3.desc'), href: `/${locale}/funktionen/dashboard/`, icon: '📊' },
  { title: t(locale, 'features.f4.title'), desc: t(locale, 'features.f4.desc'), href: `/${locale}/funktionen/verteilung/`, icon: '💰' },
  { title: t(locale, 'features.f5.title'), desc: t(locale, 'features.f5.desc'), href: `/${locale}/funktionen/steuerberichte/`, icon: '📋' },
  { title: t(locale, 'features.f6.title'), desc: t(locale, 'features.f6.desc'), href: `/${locale}/funktionen/passepartout-integration/`, icon: '🔗' },
  { title: t(locale, 'features.f7.title'), desc: t(locale, 'features.f7.desc'), href: `/${locale}/funktionen/gaestefeedback/`, icon: '⭐' },
  { title: t(locale, 'features.f8.title'), desc: t(locale, 'features.f8.desc'), href: `/${locale}/funktionen/sicherheit/`, icon: '🔒' },
];
---

<PageLayout
  title="Gratitude Funktionen | Digitales Trinkgeld fur Hotels"
  description="Entdecken Sie alle Gratitude-Funktionen: Tablet-Checkout, QR-Codes, Dashboard, Verteilung, Steuerberichte, Passepartout-Integration, Feedback, Sicherheit."
>
  <section class="section-padding">
    <div class="section-container">
      <div class="text-center mb-12">
        <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{t(locale, 'features.section_title')}</h1>
        <p class="text-lg text-stone-600 dark:text-stone-300 max-w-2xl mx-auto">
          Jeder Aspekt des digitalen Trinkgelds, verwaltet in einer einzigen Plattform, die in Ihr PMS integriert ist.
        </p>
      </div>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        {features.map(f => (
          <a href={f.href} class="group p-6 rounded-2xl bg-stone-50 dark:bg-navy-800 border border-stone-200 dark:border-navy-700 hover:shadow-lg hover:border-teal-300 dark:hover:border-teal-600 transition-all">
            <span class="text-3xl mb-3 block">{f.icon}</span>
            <h2 class="text-lg font-bold mb-2 group-hover:text-teal-700 dark:group-hover:text-teal-400 transition-colors">{f.title}</h2>
            <p class="text-sm text-stone-600 dark:text-stone-300 line-clamp-3">{f.desc}</p>
            <span class="mt-3 inline-flex items-center text-sm text-teal-700 dark:text-teal-400 font-medium group-hover:gap-2 transition-all">
              {t(locale, 'cta.more')}
              <svg class="w-4 h-4 ml-1" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>
</PageLayout>
