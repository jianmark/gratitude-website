---
import PageLayout from '@/layouts/PageLayout.astro';
import JsonLd from '@/components/seo/JsonLd.astro';
import { t, localizedUrl } from '@/i18n/utils';

const locale = 'de';

const essentialsFeatures = [
  'Tablet-Checkout mit integriertem Trinkgeld',
  'Bis zu 3 aktive QR-Codes',
  'Basis-Dashboard (Uebersicht + Trinkgeld-Register)',
  'Automatische Verteilung (fester Prozentsatz)',
  'Monatliche PDF-Berichte',
  'Passepartout Welcome Integration',
  '5 Sprachen (IT, EN, DE, FR, ES)',
  'Bis zu 5 Mitarbeiter',
  'Bis zu 3 Abteilungen',
  'E-Mail-Support',
  '1 Dashboard-Benutzer',
];
const essentialsNotIncluded = [
  'Verteilung nach Arbeitsstunden',
  'Mexal-Steuerberichte',
  'Gaestefeedback',
  'Mitarbeiter-Gamification',
  'Mitarbeiter-Benachrichtigungen',
  'Stripe-QR-Zahlungen',
  'Priorisierter Support',
];
const professionalFeatures = [
  'Bis zu 10 QR-Codes mit Analytics',
  'Vollstaendiges Dashboard (alle Module)',
  'Verteilung nach Arbeitsstunden',
  'Steuerberichte PDF + CSV Mexal',
  'Gaestefeedback mit Sentimentanalyse',
  'Stripe-QR-Zahlungen',
  'E-Mail-Benachrichtigungen fuer Mitarbeiter',
  'Mitarbeiter-Gamification und Rangliste',
  'QR-Druckvorlagen (Karte, Aufsteller, Aufkleber)',
  '8 Sprachen (IT, EN, DE, FR, ES, AR, RU, ZH)',
  'Bis zu 15 Mitarbeiter',
  'Bis zu 8 Abteilungen',
  'Priorisierter Support',
  'Bis zu 5 Dashboard-Benutzer',
  'Dedizierte Teamschulung',
];
const enterpriseFeatures = [
  'Multi-Property (zentrale Verwaltung)',
  'Unbegrenzte QR-Codes, Mitarbeiter, Abteilungen und Benutzer',
  'Garantiertes SLA mit dediziertem Support',
  'Telegram-Benachrichtigungsintegration',
  'Erweitertes Monitoring und Systemwarnungen',
  'Self-Hosted auf Kundeninfrastruktur',
  'Premium-Onboarding mit dediziertem Projektmanager',
  'Individuelle Berichte auf Anfrage',
  'Periodisches Sicherheitsaudit',
];
const faqs = [
  { q: 'Was kostet Gratitude?', a: 'Der Preis haengt von der Groesse des Hauses, der Zimmeranzahl und den gewaehlten Funktionen ab. Kontaktieren Sie uns fuer ein transparentes, unverbindliches Angebot.' },
  { q: 'Gibt es Einrichtungsgebuehren?', a: 'Installation und Erstkonfiguration sind in allen Plaenen enthalten. Unser Team konfiguriert Gratitude auf Ihrer Infrastruktur, verbindet Ihr PMS und schult Ihr Personal.' },
  { q: 'Welche Kosten fallen fuer Stripe-QR-Zahlungen an?', a: 'QR-Zahlungen nutzen Stripe Connect. Standard-Stripe-Gebuehren gelten pro Transaktion (siehe stripe.com/pricing). Gratitude erhebt keine zusaetzlichen Transaktionsgebuehren.' },
  { q: 'Muss ich Hardware kaufen?', a: 'Nein. Gratitude laeuft auf jedem vorhandenen iPad oder Android-Tablet als PWA. Keine dedizierte Hardware erforderlich.' },
  { q: 'Kann ich den Plan jederzeit wechseln?', a: 'Ja. Upgrades sind jederzeit moeglich. Downgrades sind zum Ende der Vertragslaufzeit moeglich.' },
  { q: 'Gehoeren mir meine Daten?', a: 'Absolut. Die Daten sind ausschliessliches Eigentum des Hauses. Mit dem Enterprise-Plan koennen Sie Gratitude auf Ihrer eigenen Infrastruktur hosten. In jedem Fall bieten wir jederzeit vollstaendigen Datenexport.' },
  { q: 'Wie funktioniert der Support?', a: 'Essentials umfasst E-Mail-Support zu Geschaeftszeiten. Professional umfasst priorisierten Support mit garantierten Reaktionszeiten. Enterprise umfasst einen dedizierten Ansprechpartner und individuelles SLA.' },
  { q: 'Funktioniert Gratitude ohne Passepartout?', a: 'Gratitude ist fuer Passepartout Welcome optimiert, aber das QR-Modul mit Stripe-Zahlung funktioniert unabhaengig. Kontaktieren Sie uns fuer Integrationen mit anderen PMS-Systemen.' },
  { q: 'Wie lange dauert die Installation?', a: 'In der Regel 1 Werktag fuer Essentials und Professional. Enterprise beinhaltet strukturiertes Onboarding mit dediziertem Projektmanager, typischerweise 3-5 Tage.' },
  { q: 'Gibt es eine Testphase?', a: 'Ja! Wir bieten eine kostenlose 14-taegige Testphase mit vollem Zugang zu allen Funktionen. Danach koennen Sie den passenden Plan fuer Ihr Haus waehlen.' },
];
const comparisonFeatures = [
  { name: 'Tablet-Checkout', e: true, p: true, ent: true },
  { name: 'QR-Codes', e: '3', p: '10', ent: 'Unbegrenzt' },
  { name: 'Mitarbeiter', e: '5', p: '15', ent: 'Unbegrenzt' },
  { name: 'Abteilungen', e: '3', p: '8', ent: 'Unbegrenzt' },
  { name: 'Dashboard', e: 'Basis', p: 'Vollstaendig', ent: 'Vollstaendig' },
  { name: 'Sprachen', e: '5', p: '8', ent: '8' },
  { name: 'Dashboard-Benutzer', e: '1', p: '5', ent: 'Unbegrenzt' },
  { name: 'Stundenbasierte Verteilung', e: false, p: true, ent: true },
  { name: 'Mexal-Steuerberichte', e: false, p: true, ent: true },
  { name: 'Gaestefeedback', e: false, p: true, ent: true },
  { name: 'Stripe-QR-Zahlungen', e: false, p: true, ent: true },
  { name: 'Mitarbeiter-Gamification', e: false, p: true, ent: true },
  { name: 'Mitarbeiter-Benachrichtigungen', e: false, p: true, ent: true },
  { name: 'Multi-Property', e: false, p: false, ent: true },
  { name: 'Telegram', e: false, p: false, ent: true },
  { name: 'Self-Hosted', e: false, p: false, ent: true },
  { name: 'Garantiertes SLA', e: false, p: false, ent: true },
  { name: 'Support', e: 'E-Mail', p: 'Priorisiert', ent: 'Dediziert' },
];
---

<PageLayout title={t(locale, 'meta.pricing.title')} description={t(locale, 'meta.pricing.description')}>
  <section class="section-padding bg-gradient-to-b from-navy-50 to-stone-50 dark:from-navy-950 dark:to-navy-900">
    <div class="section-container text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-bold mb-4">{t(locale, 'pricing.heading')}</h1>
      <p class="text-lg md:text-xl text-stone-600 dark:text-stone-400 max-w-3xl mx-auto">{t(locale, 'pricing.subheading')}</p>
    </div>
  </section>
  <section class="section-padding">
    <div class="section-container">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
        <div class="rounded-2xl border border-stone-200 bg-white p-8 shadow-sm dark:border-navy-700 dark:bg-navy-800/50">
          <h3 class="text-xl font-bold text-navy-800 dark:text-stone-100">{t(locale, 'pricing.essentials')}</h3>
          <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">{t(locale, 'pricing.essentials.target')}</p>
          <p class="mt-6 text-sm font-semibold text-teal-700 dark:text-teal-400">{t(locale, 'pricing.contact')}</p>
          <a href={localizedUrl(locale, '/demo/')} class="btn-secondary w-full mt-6 text-center">{t(locale, 'cta.demo.short')}</a>
          <ul class="mt-8 space-y-3">{essentialsFeatures.map((f) => (<li class="flex items-start gap-2 text-sm text-stone-700 dark:text-stone-300"><svg class="h-5 w-5 text-teal-600 dark:text-teal-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg><span>{f}</span></li>))}</ul>
          <div class="mt-6 pt-6 border-t border-stone-200 dark:border-navy-700">
            <p class="text-xs font-medium text-stone-400 dark:text-stone-500 uppercase mb-3">{t(locale, 'pricing.not_included')}</p>
            <ul class="space-y-2">{essentialsNotIncluded.map((f) => (<li class="flex items-start gap-2 text-sm text-stone-400 dark:text-stone-500"><svg class="h-5 w-5 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg><span>{f}</span></li>))}</ul>
          </div>
        </div>
        <div class="rounded-2xl border-2 border-teal-500 bg-white p-8 shadow-lg relative dark:border-teal-400 dark:bg-navy-800/50">
          <span class="absolute -top-3 left-1/2 -translate-x-1/2 badge-teal px-4 py-1 text-xs font-semibold">{t(locale, 'pricing.popular')}</span>
          <h3 class="text-xl font-bold text-navy-800 dark:text-stone-100">{t(locale, 'pricing.professional')}</h3>
          <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">{t(locale, 'pricing.professional.target')}</p>
          <p class="mt-6 text-sm font-semibold text-teal-700 dark:text-teal-400">{t(locale, 'pricing.contact')}</p>
          <a href={localizedUrl(locale, '/demo/')} class="btn-primary w-full mt-6 text-center">{t(locale, 'cta.demo.short')}</a>
          <p class="mt-8 text-xs font-medium text-stone-500 dark:text-stone-400">{t(locale, 'pricing.everything_in').replace('{plan}', 'Essentials')}</p>
          <ul class="mt-4 space-y-3">{professionalFeatures.map((f) => (<li class="flex items-start gap-2 text-sm text-stone-700 dark:text-stone-300"><svg class="h-5 w-5 text-teal-600 dark:text-teal-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg><span>{f}</span></li>))}</ul>
        </div>
        <div class="rounded-2xl border border-stone-200 bg-white p-8 shadow-sm dark:border-navy-700 dark:bg-navy-800/50">
          <h3 class="text-xl font-bold text-navy-800 dark:text-stone-100">{t(locale, 'pricing.enterprise')}</h3>
          <p class="mt-2 text-sm text-stone-500 dark:text-stone-400">{t(locale, 'pricing.enterprise.target')}</p>
          <p class="mt-6 text-sm font-semibold text-teal-700 dark:text-teal-400">{t(locale, 'pricing.contact')}</p>
          <a href={localizedUrl(locale, '/demo/')} class="btn-secondary w-full mt-6 text-center">{t(locale, 'cta.demo.short')}</a>
          <p class="mt-8 text-xs font-medium text-stone-500 dark:text-stone-400">{t(locale, 'pricing.everything_in').replace('{plan}', 'Professional')}</p>
          <ul class="mt-4 space-y-3">{enterpriseFeatures.map((f) => (<li class="flex items-start gap-2 text-sm text-stone-700 dark:text-stone-300"><svg class="h-5 w-5 text-teal-600 dark:text-teal-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg><span>{f}</span></li>))}</ul>
        </div>
      </div>
    </div>
  </section>
  <section class="section-padding bg-stone-50 dark:bg-navy-900">
    <div class="section-container">
      <h2 class="text-3xl font-serif font-bold text-center mb-12">{t(locale, 'cta.plans')}</h2>
      <div class="overflow-x-auto">
        <table class="w-full max-w-5xl mx-auto text-sm">
          <thead><tr class="border-b-2 border-stone-200 dark:border-navy-700"><th class="py-4 px-4 text-left font-medium text-stone-500 dark:text-stone-400"></th><th class="py-4 px-4 text-center font-semibold text-navy-800 dark:text-stone-200">Essentials</th><th class="py-4 px-4 text-center font-semibold text-teal-700 dark:text-teal-400">Professional</th><th class="py-4 px-4 text-center font-semibold text-navy-800 dark:text-stone-200">Enterprise</th></tr></thead>
          <tbody>{comparisonFeatures.map((row) => (<tr class="border-b border-stone-100 dark:border-navy-800"><td class="py-3 px-4 text-stone-700 dark:text-stone-300">{row.name}</td>{[row.e, row.p, row.ent].map((val) => (<td class="py-3 px-4 text-center">{val === true ? (<svg class="h-5 w-5 text-teal-600 dark:text-teal-400 mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>) : val === false ? (<svg class="h-5 w-5 text-stone-300 dark:text-navy-600 mx-auto" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /></svg>) : (<span class="text-stone-600 dark:text-stone-400">{val}</span>)}</td>))}</tr>))}</tbody>
        </table>
      </div>
    </div>
  </section>
  <section class="section-padding">
    <div class="section-container max-w-3xl mx-auto">
      <h2 class="text-3xl font-serif font-bold text-center mb-12">FAQ</h2>
      <div class="space-y-4">{faqs.map((faq) => (<details class="group rounded-xl border border-stone-200 bg-white dark:border-navy-700 dark:bg-navy-800/50"><summary class="cursor-pointer list-none flex items-center justify-between px-6 py-4 text-base font-medium text-navy-800 dark:text-stone-200 [&::-webkit-details-marker]:hidden"><span>{faq.q}</span><svg class="h-5 w-5 shrink-0 text-stone-400 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" /></svg></summary><div class="px-6 pb-4 text-sm text-stone-600 dark:text-stone-400 leading-relaxed">{faq.a}</div></details>))}</div>
    </div>
  </section>
  <section class="section-padding bg-navy-800 dark:bg-navy-950">
    <div class="section-container text-center">
      <h2 class="text-3xl font-serif font-bold text-white mb-4">{t(locale, 'pricing.cta_heading')}</h2>
      <p class="text-lg text-stone-300 max-w-2xl mx-auto mb-8">{t(locale, 'pricing.cta_body')}</p>
      <a href={localizedUrl(locale, '/kontakt/')} class="btn-primary text-lg">{t(locale, 'cta.quote')}</a>
    </div>
  </section>

  <JsonLd data={{
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    'mainEntity': faqs.map((faq) => ({
      '@type': 'Question',
      'name': faq.q,
      'acceptedAnswer': {
        '@type': 'Answer',
        'text': faq.a,
      },
    })),
  }} />
</PageLayout>
