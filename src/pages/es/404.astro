---
import PageLayout from '@/layouts/PageLayout.astro';
import { t, localizedUrl } from '@/i18n/utils';
const locale = 'es';
---

<PageLayout title={t(locale, '404.heading')}>
  <section class="section-padding bg-gradient-to-b from-navy-50 to-stone-50 dark:from-navy-950 dark:to-navy-900 min-h-[60vh] flex items-center">
    <div class="section-container text-center">
      <p class="text-7xl md:text-9xl font-serif font-bold text-teal-600/20 dark:text-teal-400/20 mb-4">404</p>
      <h1 class="text-3xl md:text-4xl font-serif font-bold text-navy-800 dark:text-stone-100 mb-4">{t(locale, '404.heading')}</h1>
      <p class="text-lg text-stone-600 dark:text-stone-400 max-w-xl mx-auto mb-8">{t(locale, '404.body')}</p>
      <a href={localizedUrl(locale, '/')} class="btn-primary text-lg">{t(locale, '404.cta')}</a>
    </div>
  </section>
</PageLayout>
